# Copy file này thành .env và điền giá trị thực
# Tạo JWT_SECRET mạnh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

PORT=4000

# Bắt buộc: ít nhất 32 ký tự, không commit vào git
JWT_SECRET=your-strong-random-secret-here-at-least-32-chars

# Danh sách origin được phép (phân cách bằng dấu phẩy)
# Ví dụ production: ALLOWED_ORIGINS=https://mecalc.anlaa.vn
# Để trống = cho phép mọi origin (chỉ dùng khi dev)
ALLOWED_ORIGINS=
